# Copy to .env and/or .env.dev (both loaded: .env first, then .env.dev overrides)
# Local MongoDB without auth
MONGODB_URI=mongodb://127.0.0.1:27017
DB_NAME=creative_spark
CORS_ORIGINS=http://localhost:3000

# Creative AI — default is OpenAI when OPENAI_API_KEY is set (LLM for SPARK, variations, etc.)
# Use AI_PROVIDER=mock only for offline / tests (no API calls).
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Reserved for future providers (not wired yet)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
LANGCHAIN_API_KEY=
XAI_API_KEY=
